{
  "extends": "../tsconfig.json",
  "compilerOptions": {
    "types": ["vitest/globals"],
    "lib": ["esnext", "dom"],
    "target": "ES2020",
    "noEmit": true,
    "strict": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": [
        "../*"
      ]
    }
  },
  "include": [
    "**/*.ts"
  ],
  "exclude": [
    "../node_modules"
  ]
}
