// Prisma schema for GreenLedger
// Uses SQLite for local dev; schema is Postgres-migratable

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// --- Enums (modelled as String fields for SQLite compatibility) ---
// SQLite doesn't support native enums. Values are enforced at the app level.
// orgBoundary: "operational_control" | "financial_control" | "equity_share"
// supplierStatus: "active" | "inactive"
// dataSourceScope1: "manual" | "csv_import"
// dataSourceScope2: "manual" | "csv_import"
// scope3CalcMethod: "spend_based" | "activity_based" | "supplier_specific"
// dataSourceScope3: "supplier_form" | "csv_import" | "proxy"
// methodologyScope: "scope_1" | "scope_2" | "scope_3"
// auditEntityType: "supplier" | "scope1" | "scope2" | "scope3" | "methodology" | "export"
// auditAction: "created" | "updated" | "submitted" | "exported"
// auditActor: "system" | "supplier" | "user"

model Company {
  id             String   @id @default(uuid())
  name           String
  country        String   @default("DE")
  reportingYear  Int
  orgBoundary    String   // "operational_control" | "financial_control" | "equity_share"

  suppliers        Supplier[]
  scope1Records    Scope1Record[]
  scope2Records    Scope2Record[]
  scope3Records    Scope3Record[]
  methodologyNotes MethodologyNote[]
  auditTrailEvents AuditTrailEvent[]
}

model Supplier {
  id              String   @id @default(uuid())
  companyId       String
  name            String
  country         String
  sector          String
  contactEmail    String
  publicFormToken String   @unique
  status          String   @default("active") // "active" | "inactive"

  company       Company        @relation(fields: [companyId], references: [id])
  scope3Records Scope3Record[]
}

model Scope1Record {
  id                    String   @id @default(uuid())
  companyId             String
  periodYear            Int
  valueTco2e            Float
  calculationMethod     String
  emissionFactorsSource String
  dataSource            String   // "manual" | "csv_import"
  assumptions           String?
  createdAt             DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

model Scope2Record {
  id                    String   @id @default(uuid())
  companyId             String
  periodYear            Int
  valueTco2e            Float
  calculationMethod     String
  emissionFactorsSource String
  dataSource            String   // "manual" | "csv_import"
  assumptions           String?
  createdAt             DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id])
}

model Scope3Category {
  id                String  @id @default(uuid())
  code              String  // e.g. "C1".."C15"
  name              String
  material          Boolean @default(false)
  materialityReason String?

  scope3Records Scope3Record[]
}

model Scope3Record {
  id                   String   @id @default(uuid())
  companyId            String
  supplierId           String?
  categoryId           String
  periodYear           Int
  valueTco2e           Float
  calculationMethod    String   // "spend_based" | "activity_based" | "supplier_specific"
  emissionFactorSource String
  dataSource           String   // "supplier_form" | "csv_import" | "proxy"
  assumptions          String?
  confidence           Float    // 0..1
  activityDataJson     String?  // JSON string (SQLite has no native Json type)
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  company  Company         @relation(fields: [companyId], references: [id])
  supplier Supplier?       @relation(fields: [supplierId], references: [id])
  category Scope3Category  @relation(fields: [categoryId], references: [id])
}

model MethodologyNote {
  id        String   @id @default(uuid())
  companyId String
  scope     String   // "scope_1" | "scope_2" | "scope_3"
  text      String
  updatedAt DateTime @updatedAt

  company Company @relation(fields: [companyId], references: [id])
}

model AuditTrailEvent {
  id         String   @id @default(uuid())
  companyId  String
  entityType String   // "supplier" | "scope1" | "scope2" | "scope3" | "methodology" | "export"
  entityId   String
  action     String   // "created" | "updated" | "submitted" | "exported"
  actor      String   // "system" | "supplier" | "user"
  timestamp  DateTime @default(now())
  comment    String?

  company Company @relation(fields: [companyId], references: [id])
}

